# City of Saints — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit the .env file to version control

# ── Database ──────────────────────────────────
DATABASE_NAME=church_cms
DATABASE_USERNAME=strapi
DATABASE_PASSWORD=          # Generate a strong password

# ── Strapi Secrets ────────────────────────────
# Generate unique random values for each:
#   node -e "console.log(require('crypto').randomBytes(16).toString('base64'))"
APP_KEYS=                   # 4 comma-separated base64 keys
API_TOKEN_SALT=             # Random base64 string
ADMIN_JWT_SECRET=           # Random base64 string
TRANSFER_TOKEN_SALT=        # Random base64 string
JWT_SECRET=                 # Random base64 string

# ── Frontend ──────────────────────────────────
SITE_URL=https://cityofsaints.pl
REVALIDATION_SECRET=        # Random string for Strapi webhook auth

# ── Environment ───────────────────────────────
NODE_ENV=production
