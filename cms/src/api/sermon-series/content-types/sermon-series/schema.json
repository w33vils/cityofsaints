{
  "kind": "collectionType",
  "collectionName": "sermon_series",
  "info": {
    "singularName": "sermon-series",
    "pluralName": "sermon-serieses",
    "displayName": "Sermon Series",
    "description": "Sermon series grouping multiple sermons"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title"
    },
    "description": {
      "type": "richtext"
    },
    "cover_image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "wide_image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "sermons": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::sermon.sermon",
      "mappedBy": "series"
    },
    "is_current": {
      "type": "boolean",
      "default": false
    }
  }
}
