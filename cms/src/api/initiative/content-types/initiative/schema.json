    "tagline": {
      "type": "string"
    },
    "description": {
      "type": "richtext"
    },
    "hero_image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "email": {
      "type": "email"
    },
    "website_url": {
      "type": "string"
    }
  }
