{
  "kind": "collectionType",
  "collectionName": "locations",
  "info": {
    "singularName": "location",
    "pluralName": "locations",
    "displayName": "Location",
    "description": "Church campus locations"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name"
    },
    "address": {
      "type": "text",
      "required": true
    },
    "city": {
      "type": "string",
      "default": "Łódź"
    },
    "postal_code": {
      "type": "string"
    },
    "voivodeship": {
      "type": "string",
      "default": "Łódzkie"
    },
    "country": {
      "type": "string",
      "default": "Poland"
    },
    "email": {
      "type": "email"
    },
    "phone": {
      "type": "string"
    },
    "service_times": {
      "type": "component",
      "repeatable": true,
      "component": "shared.service-time"
    },
    "hero_image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "card_image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "description": {
      "type": "richtext"
    },
    "google_maps_embed": {
      "type": "text"
    },
    "pastor": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::team-member.team-member"
    },
    "events": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::event.event",
      "mappedBy": "location"
    }
  }
}
