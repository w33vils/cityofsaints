{
  "kind": "collectionType",
  "collectionName": "event_registrations",
  "info": {
    "singularName": "event-registration",
    "pluralName": "event-registrations",
    "displayName": "Event Registration",
    "description": "Event registration submissions"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "event": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::event.event"
    },
    "first_name": {
      "type": "string",
      "required": true
    },
    "last_name": {
      "type": "string",
      "required": true
    },
    "email": {
      "type": "email",
      "required": true
    },
    "phone": {
      "type": "string"
    },
    "num_attendees": {
      "type": "integer",
      "default": 1
    },
    "dietary_restrictions": {
      "type": "string"
    },
    "childcare_needed": {
      "type": "boolean",
      "default": false
    },
    "notes": {
      "type": "text"
    },
    "status": {
      "type": "enumeration",
      "enum": ["confirmed", "cancelled", "waitlisted"],
      "default": "confirmed"
    },
    "registered_at": {
      "type": "datetime"
    }
  }
}
