{
  "kind": "collectionType",
  "collectionName": "ministries",
  "info": {
    "singularName": "ministry",
    "pluralName": "ministries",
    "displayName": "Ministry",
    "description": "Church ministries (Kids, Students, etc.)"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name"
    },
    "tagline": {
      "type": "string"
    },
    "description": {
      "type": "richtext"
    },
    "icon": {
      "type": "string"
    },
    "hero_image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "email": {
      "type": "email"
    },
    "social_facebook": {
      "type": "string"
    },
    "social_instagram": {
      "type": "string"
    },
    "volunteer_url": {
      "type": "string"
    },
    "what_we_do": {
      "type": "component",
      "repeatable": true,
      "component": "ministry.feature-block"
    },
    "congregation_info": {
      "type": "component",
      "repeatable": true,
      "component": "ministry.congregation-detail"
    },
    "faqs": {
      "type": "component",
      "repeatable": true,
      "component": "shared.faq"
    },
    "cta_text": {
      "type": "string"
    },
    "events": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::event.event",
      "mappedBy": "ministry"
    }
  }
}
