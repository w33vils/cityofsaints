{
  "kind": "collectionType",
  "collectionName": "team_members",
  "info": {
    "singularName": "team-member",
    "pluralName": "team-members",
    "displayName": "Team Member",
    "description": "Church staff, elders, and leadership"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name"
    },
    "title": {
      "type": "string"
    },
    "email": {
      "type": "email"
    },
    "photo": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "bio": {
      "type": "richtext"
    },
    "role": {
      "type": "enumeration",
      "enum": ["Elder", "Deacon", "Staff", "Resident", "Intern"]
    },
    "division": {
      "type": "string"
    },
    "congregation": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::location.location"
    },
    "ministry": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::ministry.ministry"
    },
    "initiative": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::initiative.initiative"
    },
    "sermons": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::sermon.sermon",
      "mappedBy": "preacher"
    }
  }
}
