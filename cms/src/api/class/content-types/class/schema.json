{
  "kind": "collectionType",
  "collectionName": "classes",
  "info": {
    "singularName": "class",
    "pluralName": "classes",
    "displayName": "Class",
    "description": "Bible studies, classes, and courses"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title"
    },
    "type": {
      "type": "enumeration",
      "enum": ["Bible Study", "Class", "Connect", "Baptism", "Other"]
    },
    "start_date": {
      "type": "date"
    },
    "end_date": {
      "type": "date"
    },
    "time": {
      "type": "string"
    },
    "location": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::location.location"
    },
    "ministry": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::ministry.ministry"
    },
    "description": {
      "type": "richtext"
    },
    "registration_url": {
      "type": "string"
    },
    "frequency": {
      "type": "enumeration",
      "enum": ["One-time", "Weekly", "Bi-weekly", "Monthly"]
    }
  }
}
